<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WinTune.Controls.TweakCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Margin="0,0,0,8"
        Padding="16,12,16,12"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <StackPanel Spacing="8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="1">
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8">
                        <TextBlock
                            x:Name="TitlePrimary"
                            FontWeight="SemiBold"
                            TextWrapping="Wrap" />
                        <FontIcon
                            x:Name="AdminBadge"
                            Margin="0,1,0,0"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorCautionBrush}"
                            Glyph="&#xE7EF;"
                            ToolTipService.ToolTip="Requires administrator · 需要管理員權限"
                            Visibility="Collapsed" />
                        <FontIcon
                            x:Name="RestartBadge"
                            Margin="0,1,0,0"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE72C;"
                            ToolTipService.ToolTip="Needs restart to apply · 需要重啟先生效"
                            Visibility="Collapsed" />
                    </StackPanel>
                    <TextBlock
                        x:Name="TitleSecondary"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="DescPrimary"
                        Margin="0,4,0,0"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="DescSecondary"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Grid
                    x:Name="ControlHost"
                    Grid.Column="1"
                    MinWidth="120"
                    VerticalAlignment="Center" />
            </Grid>

            <InfoBar
                x:Name="ResultBar"
                IsClosable="True"
                IsOpen="False" />

            <Border
                x:Name="OutputPane"
                Margin="0,2,0,0"
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="Collapsed">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="12" Glyph="&#xE756;" VerticalAlignment="Center" />
                        <TextBlock x:Name="OutputHeader" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="CopyOutBtn" Padding="8,2,8,2" Click="CopyOut_Click" />
                        <Button x:Name="SaveOutBtn" Padding="8,2,8,2" Click="SaveOut_Click" />
                    </StackPanel>
                    <ScrollViewer
                        x:Name="TableScroller"
                        HorizontalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Auto"
                        MaxHeight="360"
                        VerticalScrollBarVisibility="Auto"
                        Visibility="Collapsed">
                        <Grid x:Name="TableHost" />
                    </ScrollViewer>
                    <TextBox
                        x:Name="OutputBox"
                        AcceptsReturn="True"
                        Background="Transparent"
                        BorderThickness="0"
                        FontFamily="Consolas"
                        FontSize="12"
                        IsReadOnly="True"
                        IsSpellCheckEnabled="False"
                        MaxHeight="320"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        TextWrapping="NoWrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
