<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.TimeUnitModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE823;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Local clock -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="2">
                    <TextBlock x:Name="LocalCaption" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="LocalZone" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
                    <TextBlock x:Name="LocalTime" FontFamily="Consolas" FontSize="28" />
                    <TextBlock x:Name="LocalDate" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- World clock board -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="BoardTitle" Grid.Column="0" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <ComboBox x:Name="AddZoneBox" MinWidth="260" />
                    <Button x:Name="AddCityBtn" Click="AddCity_Click" />
                </StackPanel>
            </Grid>

            <ItemsControl x:Name="Board">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- Timezone converter -->
            <TextBlock x:Name="ConvTitle" FontWeight="SemiBold" FontSize="16" Margin="0,6,0,0" />
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="10" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="ConvWhenLabel" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <CalendarDatePicker x:Name="ConvDate" MinWidth="180" />
                            <TimePicker x:Name="ConvTime" ClockIdentifier="24HourClock" />
                            <Button x:Name="NowBtn" Click="Now_Click" />
                        </StackPanel>

                        <TextBlock x:Name="ConvFromLabel" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                        <ComboBox x:Name="ConvFrom" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" SelectionChanged="Conv_Changed" />

                        <TextBlock x:Name="ConvToLabel" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                        <ComboBox x:Name="ConvTo" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" SelectionChanged="Conv_Changed" />
                    </Grid>
                    <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="6" Padding="12,10,12,10">
                        <TextBlock x:Name="ConvResult" FontSize="15" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Unit converter (bonus) -->
            <TextBlock x:Name="UnitTitle" FontWeight="SemiBold" FontSize="16" Margin="0,6,0,0" />
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <ComboBox x:Name="UnitCategoryBox" HorizontalAlignment="Stretch" SelectionChanged="UnitCategory_Changed" />
                    <Grid ColumnSpacing="10" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="UnitValueLabel" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" />
                        <NumberBox x:Name="UnitValueBox" Grid.Row="0" Grid.Column="1" Value="1" ValueChanged="Unit_Changed" HorizontalAlignment="Stretch" />

                        <TextBlock x:Name="UnitFromLabel" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                        <ComboBox x:Name="UnitFrom" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" SelectionChanged="Unit_Changed" />

                        <TextBlock x:Name="UnitToLabel" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                        <ComboBox x:Name="UnitTo" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" SelectionChanged="Unit_Changed" />
                    </Grid>
                    <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="6" Padding="12,10,12,10">
                        <TextBlock x:Name="UnitResult" FontSize="15" FontFamily="Consolas" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
