<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.CaptureStudioModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">

            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="24" Glyph="&#xE722;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="EngineBar" IsClosable="False" IsOpen="False" />

            <!-- ============ Region record → MP4 / GIF ============ -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="RecLabel" FontWeight="SemiBold" />
                    <TextBlock x:Name="RecBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12" />

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="OutCap" Grid.Column="0" VerticalAlignment="Center" Width="80" />
                        <TextBox x:Name="OutputBox" Grid.Column="1" IsReadOnly="True" />
                        <Button x:Name="ChangeBtn" Grid.Column="2" Click="Change_Click" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="FpsCap" VerticalAlignment="Center" />
                            <NumberBox x:Name="FpsBox" Value="30" Minimum="5" Maximum="60" SpinButtonPlacementMode="Inline" MinWidth="120" />
                        </StackPanel>
                        <CheckBox x:Name="GifChk" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Button x:Name="RecordBtn" Click="Record_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="StopBtn" Click="Stop_Click" IsEnabled="False" />
                        <Ellipse x:Name="Dot" Width="12" Height="12" Fill="Red" Visibility="Collapsed" />
                        <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontFamily="Consolas" />
                    </StackPanel>
                    <InfoBar x:Name="RecBar" IsClosable="True" IsOpen="False" />
                </StackPanel>
            </Border>

            <!-- ============ Instant snip → clipboard ============ -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="SnipLabel" FontWeight="SemiBold" />
                    <TextBlock x:Name="SnipBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="SnipBtn" Click="Snip_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="SaveSnipBtn" Click="SaveSnip_Click" IsEnabled="False" />
                    </StackPanel>
                    <Border x:Name="PreviewBorder" Visibility="Collapsed" CornerRadius="6" MaxHeight="260"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" HorizontalAlignment="Left">
                        <Image x:Name="SnipPreview" Stretch="None" />
                    </Border>
                    <InfoBar x:Name="SnipBar" IsClosable="True" IsOpen="False" />
                </StackPanel>
            </Border>

            <!-- ============ OCR ============ -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="OcrLabel" FontWeight="SemiBold" />
                    <TextBlock x:Name="OcrBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12" />
                    <TextBlock x:Name="OcrLangs" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" FontSize="12" />
                    <InfoBar x:Name="OcrLangBar" IsClosable="False" IsOpen="False" Severity="Warning" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="OcrRegionBtn" Click="OcrRegion_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="OcrFileBtn" Click="OcrFile_Click" />
                    </StackPanel>
                    <TextBox x:Name="OcrResult" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="80" MaxHeight="220" Visibility="Collapsed"
                             FontFamily="Consolas" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    <InfoBar x:Name="OcrBar" IsClosable="True" IsOpen="False" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
