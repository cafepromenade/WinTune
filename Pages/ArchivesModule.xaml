<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.ArchivesModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1100" Spacing="14">

            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="24" Glyph="&#xE7B8;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="EngineBar" IsClosable="False" IsOpen="False" />

            <!-- Selection -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="SelLabel" FontWeight="SemiBold" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ArcCap" Grid.Column="0" VerticalAlignment="Center" Width="70" />
                        <TextBox x:Name="ArchiveBox" Grid.Column="1" IsReadOnly="True" />
                        <Button x:Name="OpenArcBtn" Grid.Column="2" Click="OpenArchive_Click" />
                        <Button x:Name="NewArcBtn" Grid.Column="3" Click="NewArchive_Click" />
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SrcCap" Grid.Column="0" VerticalAlignment="Center" Width="70" />
                        <TextBox x:Name="SourceBox" Grid.Column="1" IsReadOnly="True" />
                        <Button x:Name="SrcFileBtn" Grid.Column="2" Click="SourceFile_Click" />
                        <Button x:Name="SrcFolderBtn" Grid.Column="3" Click="SourceFolder_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Create -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="CreateLabel" FontWeight="SemiBold" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="FormatBox" Grid.Column="0" MinWidth="110" SelectedIndex="0">
                            <ComboBoxItem Content="7z" Tag="7z" />
                            <ComboBoxItem Content="zip" Tag="zip" />
                            <ComboBoxItem Content="tar" Tag="tar" />
                            <ComboBoxItem Content="gzip" Tag="gzip" />
                            <ComboBoxItem Content="bzip2" Tag="bzip2" />
                            <ComboBoxItem Content="xz" Tag="xz" />
                        </ComboBox>
                        <ComboBox x:Name="LevelBox" Grid.Column="1" MinWidth="150" SelectedIndex="2">
                            <ComboBoxItem Content="0 · Store · 唔壓縮" Tag="0" />
                            <ComboBoxItem Content="1 · Fast · 快" Tag="1" />
                            <ComboBoxItem Content="5 · Normal · 普通" Tag="5" />
                            <ComboBoxItem Content="9 · Ultra · 極限" Tag="9" />
                        </ComboBox>
                        <PasswordBox x:Name="PasswordBox" Grid.Column="2" />
                        <Button x:Name="CreateBtn" Grid.Column="3" Click="Create_Click" Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="VolumeBox" Grid.Column="0" Width="150" />
                        <CheckBox x:Name="SfxCheck" Grid.Column="1" />
                        <CheckBox x:Name="HeaderEncCheck" Grid.Column="2" IsChecked="True" />
                        <CheckBox x:Name="SolidCheck" Grid.Column="3" />
                        <CheckBox x:Name="MtCheck" Grid.Column="4" IsChecked="True" />
                    </Grid>
                    <TextBlock x:Name="RarNote" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Quick ops -->
            <StackPanel x:Name="QuickOps" Orientation="Horizontal" Spacing="8" />

            <!-- Output -->
            <Border x:Name="OutBorder" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6" Visibility="Collapsed">
                <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="OutText" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True" TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>

            <!-- Advanced operations -->
            <TextBlock x:Name="AdvancedHeader" Style="{StaticResource SubtitleTextBlockStyle}" />
            <AutoSuggestBox x:Name="OpsFilter" MaxWidth="420" HorizontalAlignment="Left" QueryIcon="Find" TextChanged="OpsFilter_TextChanged" />
            <StackPanel x:Name="OpsPanel" />
        </StackPanel>
    </ScrollViewer>
</Page>
