<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.ScreenRecorderModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE714;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="EngineBar" IsClosable="False" IsOpen="False" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="OutCap" Grid.Column="0" VerticalAlignment="Center" Width="70" />
                        <TextBox x:Name="OutputBox" Grid.Column="1" IsReadOnly="True" />
                        <Button x:Name="ChangeBtn" Grid.Column="2" Click="Change_Click" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock x:Name="FpsCap" VerticalAlignment="Center" />
                        <NumberBox x:Name="FpsBox" Value="30" Minimum="5" Maximum="60" SpinButtonPlacementMode="Inline" MinWidth="130" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button x:Name="RecordBtn" Click="Record_Click" Style="{StaticResource AccentButtonStyle}" />
                <Button x:Name="StopBtn" Click="Stop_Click" IsEnabled="False" />
                <Ellipse x:Name="Dot" Width="12" Height="12" Fill="Red" Visibility="Collapsed" />
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontFamily="Consolas" />
            </StackPanel>

            <InfoBar x:Name="ResultBar" IsClosable="True" IsOpen="False" />
        </StackPanel>
    </ScrollViewer>
</Page>
