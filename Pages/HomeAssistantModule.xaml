<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.HomeAssistantModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="980" Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE80F;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <!-- Connection / config -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="CfgTitle" FontWeight="SemiBold" FontSize="16" />
                    <TextBox x:Name="UrlBox" PlaceholderText="http://homeassistant.local:8123" FontFamily="Consolas" />
                    <PasswordBox x:Name="TokenBox" PlaceholderText="Long-lived access token · 長期存取權杖" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="SaveCfgBtn" Click="SaveCfg_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="TestBtn" Click="Test_Click" />
                        <ProgressRing x:Name="CfgBusy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                    </StackPanel>
                    <InfoBar x:Name="CfgResult" IsClosable="True" IsOpen="False" />
                </StackPanel>
            </Border>

            <Pivot x:Name="Tabs" SelectionChanged="Tabs_SelectionChanged">
                <!-- Template -->
                <PivotItem x:Name="TabTemplate">
                    <StackPanel Spacing="10" Margin="0,12,0,0">
                        <TextBlock x:Name="TplBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <TextBox x:Name="TplBox" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" MinHeight="80" />
                        <Button x:Name="TplRunBtn" Click="TplRun_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                            <TextBox x:Name="TplOut" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12" BorderThickness="0" Background="Transparent" MinHeight="60" />
                        </Border>
                    </StackPanel>
                </PivotItem>

                <!-- Config / restart / reload -->
                <PivotItem x:Name="TabConfig">
                    <StackPanel Spacing="10" Margin="0,12,0,0">
                        <TextBlock x:Name="CcBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="CheckCfgBtn" Click="CheckCfg_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="RestartBtn" Click="Restart_Click" />
                            <ProgressRing x:Name="CcBusy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="ReloadLbl" FontWeight="SemiBold" FontSize="13" Margin="0,6,0,0" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ReloadDomainBox" Grid.Column="0" SelectedIndex="0" HorizontalAlignment="Stretch" />
                            <Button x:Name="ReloadDomainBtn" Grid.Column="1" Click="ReloadDomain_Click" />
                        </Grid>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="EntryIdBox" Grid.Column="0" PlaceholderText="config_entry_id" FontFamily="Consolas" />
                            <Button x:Name="ReloadEntryBtn" Grid.Column="1" Click="ReloadEntry_Click" />
                        </Grid>
                        <InfoBar x:Name="CcResult" IsClosable="True" IsOpen="False" />
                    </StackPanel>
                </PivotItem>

                <!-- States / history / set state -->
                <PivotItem x:Name="TabStates">
                    <StackPanel Spacing="10" Margin="0,12,0,0">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <AutoSuggestBox x:Name="EntityPick" Grid.Column="0" PlaceholderText="sensor.temperature" FontFamily="Consolas" />
                            <Button x:Name="LoadEntitiesBtn" Grid.Column="1" Click="LoadEntities_Click" />
                        </Grid>

                        <TextBlock x:Name="HistLbl" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,0" />
                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="10" MinHeight="90">
                            <Grid>
                                <Polyline x:Name="Spark" Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="1.5" />
                                <TextBlock x:Name="SparkInfo" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" VerticalAlignment="Top" />
                            </Grid>
                        </Border>
                        <Button x:Name="HistBtn" Click="Hist_Click" />

                        <TextBlock x:Name="SetStateLbl" FontWeight="SemiBold" FontSize="13" Margin="0,6,0,0" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="StateValBox" Grid.Column="0" PlaceholderText="state" />
                            <TextBox x:Name="StateAttrBox" Grid.Column="1" PlaceholderText="{}{&quot;unit&quot;:&quot;C&quot;} (optional JSON)" FontFamily="Consolas" />
                            <Button x:Name="SetStateBtn" Grid.Column="2" Click="SetState_Click" />
                        </Grid>
                        <InfoBar x:Name="StResult" IsClosable="True" IsOpen="False" />
                    </StackPanel>
                </PivotItem>

                <!-- Scenes / scripts / events / intents -->
                <PivotItem x:Name="TabAuto">
                    <StackPanel Spacing="10" Margin="0,12,0,0">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="SceneBox" Grid.Column="0" HorizontalAlignment="Stretch" />
                            <Button x:Name="SceneBtn" Grid.Column="1" Click="Scene_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="ReloadScenesBtn" Grid.Column="2" Click="ReloadScenes_Click" />
                        </Grid>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ScriptBox" Grid.Column="0" HorizontalAlignment="Stretch" />
                            <Button x:Name="ScriptBtn" Grid.Column="1" Click="Script_Click" />
                        </Grid>

                        <TextBlock x:Name="EventLbl" FontWeight="SemiBold" FontSize="13" Margin="0,6,0,0" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="EventTypeBox" Grid.Column="0" PlaceholderText="wintune_pc_locked" FontFamily="Consolas" />
                            <TextBox x:Name="EventDataBox" Grid.Column="1" PlaceholderText="{}{&quot;source&quot;:&quot;wintune&quot;} (optional JSON)" FontFamily="Consolas" />
                            <Button x:Name="EventBtn" Grid.Column="2" Click="Event_Click" />
                        </Grid>

                        <TextBlock x:Name="IntentLbl" FontWeight="SemiBold" FontSize="13" Margin="0,6,0,0" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="IntentNameBox" Grid.Column="0" PlaceholderText="HassTurnOn" FontFamily="Consolas" />
                            <TextBox x:Name="IntentDataBox" Grid.Column="1" PlaceholderText="{}{&quot;name&quot;:&quot;kitchen&quot;} (optional JSON)" FontFamily="Consolas" />
                            <Button x:Name="IntentBtn" Grid.Column="2" Click="Intent_Click" />
                        </Grid>
                        <InfoBar x:Name="AutoResult" IsClosable="True" IsOpen="False" />
                    </StackPanel>
                </PivotItem>

                <!-- Lights / climate -->
                <PivotItem x:Name="TabDevices">
                    <StackPanel Spacing="10" Margin="0,12,0,0">
                        <TextBlock x:Name="LightLbl" FontWeight="SemiBold" FontSize="13" />
                        <ComboBox x:Name="LightBox" HorizontalAlignment="Stretch" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock x:Name="BrightLbl" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Slider x:Name="BrightSlider" Minimum="0" Maximum="100" Value="80" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock x:Name="TempLbl" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Slider x:Name="ColorTempSlider" Minimum="2000" Maximum="6500" StepFrequency="100" Value="4000" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="LightOnBtn" Click="LightOn_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="LightOffBtn" Click="LightOff_Click" />
                        </StackPanel>

                        <TextBlock x:Name="ClimateLbl" FontWeight="SemiBold" FontSize="13" Margin="0,6,0,0" />
                        <ComboBox x:Name="ClimateBox" HorizontalAlignment="Stretch" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <NumberBox x:Name="TempBox" Grid.Column="0" Value="21" SpinButtonPlacementMode="Inline" SmallChange="0.5" />
                            <Button x:Name="SetTempBtn" Grid.Column="1" Click="SetTemp_Click" />
                            <ComboBox x:Name="HvacBox" Grid.Column="2" HorizontalAlignment="Stretch" SelectedIndex="0" />
                            <Button x:Name="SetHvacBtn" Grid.Column="3" Click="SetHvac_Click" />
                        </Grid>
                        <InfoBar x:Name="DevResult" IsClosable="True" IsOpen="False" />
                    </StackPanel>
                </PivotItem>

                <!-- Notify -->
                <PivotItem x:Name="TabNotify">
                    <StackPanel Spacing="10" Margin="0,12,0,0">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="NotifyTargetBox" Grid.Column="0" HorizontalAlignment="Stretch" />
                            <Button x:Name="LoadTargetsBtn" Grid.Column="1" Click="LoadTargets_Click" />
                        </Grid>
                        <TextBox x:Name="NotifyTitleBox" PlaceholderText="Title · 標題" />
                        <TextBox x:Name="NotifyMsgBox" PlaceholderText="Message · 訊息" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" />
                        <Button x:Name="NotifyBtn" Click="Notify_Click" Style="{StaticResource AccentButtonStyle}" />
                        <InfoBar x:Name="NotifyResult" IsClosable="True" IsOpen="False" />
                    </StackPanel>
                </PivotItem>

                <!-- Camera -->
                <PivotItem x:Name="TabCamera">
                    <StackPanel Spacing="10" Margin="0,12,0,0">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CameraBox" Grid.Column="0" HorizontalAlignment="Stretch" />
                            <Button x:Name="SnapBtn" Grid.Column="1" Click="Snap_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="SaveSnapBtn" Grid.Column="2" Click="SaveSnap_Click" />
                        </Grid>
                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="6" MinHeight="180">
                            <Image x:Name="CameraImg" Stretch="Uniform" MaxHeight="360" />
                        </Border>
                        <InfoBar x:Name="CamResult" IsClosable="True" IsOpen="False" />
                    </StackPanel>
                </PivotItem>

                <!-- Calendar -->
                <PivotItem x:Name="TabCalendar">
                    <StackPanel Spacing="10" Margin="0,12,0,0">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CalendarBox" Grid.Column="0" HorizontalAlignment="Stretch" />
                            <Button x:Name="LoadCalsBtn" Grid.Column="1" Click="LoadCals_Click" />
                            <Button x:Name="TodayBtn" Grid.Column="2" Click="Today_Click" Style="{StaticResource AccentButtonStyle}" />
                        </Grid>
                        <ListView x:Name="CalList" SelectionMode="None" MaxHeight="260">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="6,4,6,4" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Start}" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Summary}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <InfoBar x:Name="CalResult" IsClosable="True" IsOpen="False" />
                    </StackPanel>
                </PivotItem>

                <!-- Error log -->
                <PivotItem x:Name="TabLog">
                    <StackPanel Spacing="10" Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="TailBtn" Click="Tail_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="CopyLogBtn" Click="CopyLog_Click" />
                            <ProgressRing x:Name="LogBusy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                        </StackPanel>
                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                            <TextBox x:Name="LogOut" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12" BorderThickness="0" Background="Transparent" MinHeight="220" MaxHeight="420" />
                        </Border>
                    </StackPanel>
                </PivotItem>
            </Pivot>
        </StackPanel>
    </ScrollViewer>
</Page>
