<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.AppUninstallerModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:conv="using:WinTune.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:UriToImageConverter x:Key="UriImg" />
    </Page.Resources>

    <Grid Padding="24,16,24,16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <FontIcon FontSize="22" Glyph="&#xE74D;" VerticalAlignment="Center" />
            <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
        </StackPanel>
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <Grid Grid.Row="2" ColumnSpacing="8" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <AutoSuggestBox x:Name="FilterBox" Grid.Column="0" MaxWidth="460" HorizontalAlignment="Left" QueryIcon="Find" TextChanged="Filter_TextChanged" />
            <TextBlock x:Name="CountText" Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Button x:Name="RefreshBtn" Grid.Column="2" Click="Refresh_Click" />
        </Grid>

        <Border
            Grid.Row="3"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
            <ListView x:Name="List" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,6,8,6" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="36" Height="36" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE977;" FontSize="22" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <Image Source="{Binding LogoUri, Converter={StaticResource UriImg}}" Width="36" Height="36" Stretch="Uniform" />
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Name}" FontSize="11" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="92">
                                <TextBlock Text="{Binding SizeText}" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding Version}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Button Grid.Column="3" Click="Actions_Click" Padding="10,5,10,5" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                    <TextBlock Text="Uninstall · 解除安裝" />
                                    <FontIcon Glyph="&#xE70D;" FontSize="9" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock x:Name="EmptyText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="Collapsed" />
            </Grid>
        </Border>

        <InfoBar x:Name="ResultBar" Grid.Row="4" IsClosable="True" IsOpen="False" />
    </Grid>
</Page>
