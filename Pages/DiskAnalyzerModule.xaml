<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.DiskAnalyzerModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <FontIcon FontSize="22" Glyph="&#xEDA2;" VerticalAlignment="Center" />
            <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
        </StackPanel>
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <Grid Grid.Row="2" ColumnSpacing="8" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="UpBtn" Grid.Column="0" Click="Up_Click" ToolTipService.ToolTip="Up · 上一層"><FontIcon Glyph="&#xE74A;" FontSize="14" /></Button>
            <Button x:Name="BrowseBtn" Grid.Column="1" Click="Browse_Click" />
            <TextBox x:Name="FolderBox" Grid.Column="2" IsReadOnly="True" />
            <ComboBox x:Name="ModeBox" Grid.Column="3" MinWidth="150" SelectionChanged="Mode_Changed" />
            <Button x:Name="ScanBtn" Grid.Column="4" Click="Scan_Click" Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <Border
            Grid.Row="3"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <ListView x:Name="List" IsItemClickEnabled="True" ItemClick="List_ItemClick" SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,5,8,5" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="55" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="{Binding Glyph}" FontSize="14" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                <Border Height="4" Width="{Binding BarWidth}" HorizontalAlignment="Left" CornerRadius="2" Background="{ThemeResource AccentFillColorDefaultBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding SizeText}" VerticalAlignment="Center" HorizontalTextAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Column="3" Text="{Binding Percent}" VerticalAlignment="Center" HorizontalTextAlignment="Right" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="11" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
            <Button x:Name="RecycleBtn" Click="Recycle_Click" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <InfoBar x:Name="ResultBar" Grid.Row="5" IsClosable="True" IsOpen="False" />
    </Grid>
</Page>
