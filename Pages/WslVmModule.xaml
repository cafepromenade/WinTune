<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.WslVmModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <FontIcon FontSize="22" Glyph="&#xEC7A;" VerticalAlignment="Center" />
            <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
        </StackPanel>
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <InfoBar x:Name="ResultBar" Grid.Row="2" IsClosable="True" IsOpen="False" Margin="0,2,0,0" />

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14">

                <!-- ── WSL distro manager ───────────────────────────────────── -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="WslSectionTitle" Style="{StaticResource SubtitleTextBlockStyle}" />

                        <InfoBar x:Name="WslEngineBar" IsClosable="False" IsOpen="False" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="WslRefreshBtn" Click="WslRefresh_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                    <TextBlock x:Name="WslRefreshTxt" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="WslShutdownBtn" Click="WslShutdown_Click" />
                            <Button x:Name="WslImportBtn" Click="WslImport_Click" />
                            <ProgressRing x:Name="WslBusy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- installed distros list -->
                        <ListView x:Name="DistroList" SelectionMode="Single" MaxHeight="280"
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="4,6" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Display}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <Button Grid.Column="1" Content="&#xE712;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" Tag="{Binding Name}" Click="DistroActions_Click">
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Launch terminal · 開終端機" Tag="{Binding Name}" Click="DistroLaunch_Click" />
                                                    <MenuFlyoutItem Text="Set as default · 設為預設" Tag="{Binding Name}" Click="DistroSetDefault_Click" />
                                                    <MenuFlyoutItem Text="Export (back up) · 匯出（備份）" Tag="{Binding Name}" Click="DistroExport_Click" />
                                                    <MenuFlyoutItem Text="Terminate (stop) · 終止（停止）" Tag="{Binding Name}" Click="DistroTerminate_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Unregister (delete) · 移除（刪除）" Tag="{Binding Name}" Click="DistroUnregister_Click" />
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock x:Name="DistroEmpty" Visibility="Collapsed" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                        <!-- install a new distro -->
                        <TextBlock x:Name="InstallTitle" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,4,0,0" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="OnlineBox" Grid.Column="0" HorizontalAlignment="Stretch" />
                            <Button x:Name="InstallBtn" Grid.Column="1" Click="Install_Click" Style="{StaticResource AccentButtonStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Windows Sandbox launcher ─────────────────────────────── -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="SandboxSectionTitle" Style="{StaticResource SubtitleTextBlockStyle}" />

                        <InfoBar x:Name="SandboxEngineBar" IsClosable="False" IsOpen="False" />

                        <TextBlock x:Name="MapTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MapFolderBox" Grid.Column="0" PlaceholderText="C:\path\to\share" />
                            <CheckBox x:Name="MapReadOnly" Grid.Column="1" VerticalAlignment="Center" />
                            <Button x:Name="MapBrowseBtn" Grid.Column="2" Click="MapBrowse_Click" Content="&#xE838;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox x:Name="NetworkingChk" IsChecked="True" />
                            <CheckBox x:Name="VGpuChk" IsChecked="False" />
                            <CheckBox x:Name="ClipboardChk" IsChecked="True" />
                        </StackPanel>

                        <TextBlock x:Name="LogonTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBox x:Name="LogonBox" PlaceholderText="explorer.exe" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="LaunchSandboxBtn" Click="LaunchSandbox_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="PreviewWsbBtn" Click="PreviewWsb_Click" />
                            <Button x:Name="SaveWsbBtn" Click="SaveWsb_Click" />
                            <ProgressRing x:Name="SbBusy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                        </StackPanel>

                        <Border x:Name="WsbPreviewCard" Visibility="Collapsed" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                            <TextBox x:Name="WsbPreview" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12" BorderThickness="0" Background="Transparent" MinHeight="120" />
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
