<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.OneDriveModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <FontIcon FontSize="22" Glyph="&#xE753;" VerticalAlignment="Center" />
            <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
        </StackPanel>
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <!-- Folder picker / path bar -->
        <Grid Grid.Row="2" ColumnSpacing="8" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="UpBtn" Grid.Column="0" Click="Up_Click" ToolTipService.ToolTip="Up · 上一層">
                <FontIcon Glyph="&#xE74A;" FontSize="14" />
            </Button>
            <Button x:Name="PickBtn" Grid.Column="1" Click="Pick_Click" />
            <TextBox x:Name="PathBox" Grid.Column="2" IsReadOnly="True" VerticalAlignment="Center" />
            <Button x:Name="RefreshBtn" Grid.Column="3" Click="Refresh_Click" />
        </Grid>

        <!-- Selection actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
            <Button x:Name="PinBtn" Click="Pin_Click" Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE718;" FontSize="14" />
                    <TextBlock x:Name="PinBtnText" />
                </StackPanel>
            </Button>
            <Button x:Name="DehydrateBtn" Click="Dehydrate_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xEBD3;" FontSize="14" />
                    <TextBlock x:Name="DehydrateBtnText" />
                </StackPanel>
            </Button>
            <AppBarSeparator />
            <Button x:Name="SelectAllBtn" Click="SelectAll_Click" />
            <Button x:Name="ClearSelBtn" Click="ClearSel_Click" />
            <TextBlock x:Name="SelCountText" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </StackPanel>

        <!-- Sync + threshold controls -->
        <Border Grid.Row="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8"
                Padding="14,12,14,12" Margin="0,4,0,0">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="PauseBtn" Grid.Column="0" Click="Pause_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE769;" FontSize="14" />
                        <TextBlock x:Name="PauseBtnText" />
                    </StackPanel>
                </Button>
                <Button x:Name="ResumeBtn" Grid.Column="1" Click="Resume_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE768;" FontSize="14" />
                        <TextBlock x:Name="ResumeBtnText" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Center" MinWidth="180">
                    <TextBlock x:Name="ThresholdLabel" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <NumberBox x:Name="ThresholdBox" Minimum="0" Maximum="3650" SmallChange="1" LargeChange="7"
                               SpinButtonPlacementMode="Inline" Value="0" />
                </StackPanel>
                <Button x:Name="ApplyThresholdBtn" Grid.Column="4" VerticalAlignment="Bottom" Click="ApplyThreshold_Click" />
            </Grid>
        </Border>

        <!-- Entry list -->
        <Border Grid.Row="5"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <ListView x:Name="List" SelectionMode="Multiple"
                          SelectionChanged="List_SelectionChanged"
                          DoubleTapped="List_DoubleTapped">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,6,8,6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="{Binding Glyph}" FontSize="18" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SubText}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                                <Border Grid.Column="2" VerticalAlignment="Center" Padding="8,2,8,2" CornerRadius="10"
                                        Background="{Binding StateBrush}">
                                    <TextBlock Text="{Binding StateText}" FontSize="11" Foreground="White" />
                                </Border>
                                <TextBlock Grid.Column="3" Text="{Binding SizeText}" VerticalAlignment="Center"
                                           HorizontalTextAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" Padding="24">
                    <FontIcon Glyph="&#xE753;" FontSize="40" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock x:Name="EmptyText" HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                    <Button x:Name="EmptyPickBtn" HorizontalAlignment="Center" Click="Pick_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <InfoBar x:Name="ResultBar" Grid.Row="6" IsClosable="True" IsOpen="False" />
    </Grid>
</Page>
