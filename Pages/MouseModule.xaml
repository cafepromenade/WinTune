<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.MouseModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="780" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE962;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <StackPanel x:Name="Root" Spacing="10" Margin="0,4,0,0" />
        </StackPanel>
    </ScrollViewer>
</Page>
