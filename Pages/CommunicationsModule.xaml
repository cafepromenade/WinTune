<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.CommunicationsModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE8BD;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="ResultBar" IsClosable="True" IsOpen="False" />

            <!-- ============ MAIL ============ -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="MailTitle" FontWeight="SemiBold" FontSize="16" />
                    <InfoBar x:Name="OutlookBar" IsClosable="False" IsOpen="False" />
                    <TextBox x:Name="MailTo" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="MailCc" Grid.Column="0" />
                        <TextBox x:Name="MailBcc" Grid.Column="1" />
                    </Grid>
                    <TextBox x:Name="MailSubject" />
                    <TextBox x:Name="MailBody" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="MailtoBtn" Click="Mailto_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="OutlookBtn" Click="Outlook_Click" />
                    </StackPanel>

                    <TextBlock x:Name="AttachLabel" FontWeight="SemiBold" FontSize="13" Margin="0,6,0,0" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AttachPath" Grid.Column="0" FontFamily="Consolas" IsReadOnly="True" />
                        <Button x:Name="AttachBrowseBtn" Grid.Column="1" Click="AttachBrowse_Click" />
                        <Button x:Name="AttachSendBtn" Grid.Column="2" Click="AttachSend_Click" />
                    </Grid>

                    <TextBlock x:Name="FolderLabel" FontWeight="SemiBold" FontSize="13" Margin="0,6,0,0" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="FolderBox" Grid.Column="0" SelectedIndex="0" HorizontalAlignment="Stretch" />
                        <Button x:Name="FolderBtn" Grid.Column="1" Click="Folder_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ DISCORD ============ -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="DiscordTitle" FontWeight="SemiBold" FontSize="16" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DiscordGuild" Grid.Column="0" FontFamily="Consolas" />
                        <TextBox x:Name="DiscordChannel" Grid.Column="1" FontFamily="Consolas" />
                        <Button x:Name="DiscordChannelBtn" Grid.Column="2" Click="DiscordChannel_Click" Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DiscordDm" Grid.Column="0" FontFamily="Consolas" />
                        <Button x:Name="DiscordDmBtn" Grid.Column="1" Click="DiscordDm_Click" />
                        <Button x:Name="DiscordHomeBtn" Grid.Column="2" Click="DiscordHome_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ TEAMS ============ -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="TeamsTitle" FontWeight="SemiBold" FontSize="16" />
                    <!-- Chat -->
                    <TextBox x:Name="TeamsUsers" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TeamsTopic" Grid.Column="0" />
                        <TextBox x:Name="TeamsMessage" Grid.Column="1" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="TeamsChatBtn" Click="TeamsChat_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="TeamsCallBtn" Click="TeamsCall_Click" />
                    </StackPanel>
                    <!-- Meeting -->
                    <TextBlock x:Name="TeamsMeetingLabel" FontWeight="SemiBold" FontSize="13" Margin="0,6,0,0" />
                    <TextBox x:Name="TeamsMtgSubject" />
                    <TextBox x:Name="TeamsMtgAttendees" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <DatePicker x:Name="TeamsStartDate" Grid.Column="0" />
                        <TimePicker x:Name="TeamsStartTime" Grid.Column="1" ClockIdentifier="24HourClock" />
                        <DatePicker x:Name="TeamsEndDate" Grid.Column="2" />
                        <TimePicker x:Name="TeamsEndTime" Grid.Column="3" ClockIdentifier="24HourClock" />
                    </Grid>
                    <Button x:Name="TeamsMeetingBtn" Click="TeamsMeeting_Click" />
                </StackPanel>
            </Border>

            <!-- ============ TELEGRAM ============ -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="TelegramTitle" FontWeight="SemiBold" FontSize="16" />
                    <TextBox x:Name="TgShareUrl" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TgShareText" Grid.Column="0" />
                        <Button x:Name="TgShareBtn" Grid.Column="1" Click="TgShare_Click" Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TgUsername" Grid.Column="0" />
                        <TextBox x:Name="TgPost" Grid.Column="1" Width="120" FontFamily="Consolas" />
                        <Button x:Name="TgResolveBtn" Grid.Column="2" Click="TgResolve_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ SLACK ============ -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="SlackTitle" FontWeight="SemiBold" FontSize="16" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SlackTeam" Grid.Column="0" FontFamily="Consolas" />
                        <TextBox x:Name="SlackChannel" Grid.Column="1" FontFamily="Consolas" />
                        <Button x:Name="SlackChannelBtn" Grid.Column="2" Click="SlackChannel_Click" Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SlackUser" Grid.Column="0" FontFamily="Consolas" />
                        <Button x:Name="SlackDmBtn" Grid.Column="1" Click="SlackDm_Click" />
                        <Button x:Name="SlackOpenBtn" Grid.Column="2" Click="SlackOpen_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ PHONE LINK ============ -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="PhoneTitle" FontWeight="SemiBold" FontSize="16" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PhoneNumber" Grid.Column="0" Width="180" FontFamily="Consolas" />
                        <TextBox x:Name="PhoneSmsBody" Grid.Column="1" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="PhoneCallBtn" Click="PhoneCall_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button x:Name="PhoneSmsBtn" Click="PhoneSms_Click" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ DEFAULTS ============ -->
            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="DefaultsTitle" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock x:Name="DefaultsBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="13" />
                    <Button x:Name="DefaultsBtn" Click="Defaults_Click" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
