<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.VoiceModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="820" Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE767;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="NoVoiceBar" IsOpen="False" IsClosable="False" Severity="Warning" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="TextLabel" FontWeight="SemiBold" />
                        <TextBox x:Name="TextBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="140" PlaceholderText="" />
                    </StackPanel>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock x:Name="VoiceLabel" FontWeight="SemiBold" />
                            <ComboBox x:Name="VoiceCombo" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="RateLabel" FontWeight="SemiBold" />
                            <Slider x:Name="RateSlider" Minimum="-10" Maximum="10" Value="0" StepFrequency="1" TickFrequency="5" TickPlacement="Outside" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock x:Name="VolumeLabel" FontWeight="SemiBold" />
                            <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="100" StepFrequency="1" TickFrequency="25" TickPlacement="Outside" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="PlayBtn" Click="Play_Click" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE768;" />
                                <TextBlock x:Name="PlayText" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="StopBtn" Click="Stop_Click" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE71A;" />
                                <TextBlock x:Name="StopText" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ExportBtn" Click="Export_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                <TextBlock x:Name="ExportText" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <InfoBar x:Name="ResultBar" IsOpen="False" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
