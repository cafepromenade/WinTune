<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.PackageManagerModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="24" Glyph="&#xECAA;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock
                x:Name="HeaderBlurb"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>

        <!-- Manager filter -->
        <Border
            Grid.Row="1"
            Padding="14,10,14,10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="6">
                <TextBlock x:Name="ManagersLabel" FontWeight="SemiBold" FontSize="13" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Auto" VerticalScrollMode="Disabled">
                    <StackPanel x:Name="ManagerFilters" Orientation="Horizontal" Spacing="14" />
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Controls -->
        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="ViewCombo" Grid.Column="0" MinWidth="160" SelectionChanged="View_Changed" />
            <AutoSuggestBox
                x:Name="SearchBox"
                Grid.Column="1"
                QueryIcon="Find"
                QuerySubmitted="Search_Submitted" />
            <Button x:Name="PrimaryActionBtn" Grid.Column="2" Click="PrimaryAction_Click" />
            <Button x:Name="SecondaryActionBtn" Grid.Column="3" Click="SecondaryAction_Click" />
            <ProgressRing x:Name="Busy" Grid.Column="4" Width="22" Height="22" IsActive="False" VerticalAlignment="Center" />
        </Grid>

        <!-- Results -->
        <Grid Grid.Row="3" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                x:Name="ResultsHeader"
                Grid.Row="0"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ResultsPanel" Spacing="6" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
