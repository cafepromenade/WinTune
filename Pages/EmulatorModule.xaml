<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.EmulatorModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <FontIcon FontSize="22" Glyph="&#xE8EA;" VerticalAlignment="Center" />
            <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
        </StackPanel>
        <TextBlock x:Name="HeaderBlurb" Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <InfoBar x:Name="EngineBar" Grid.Row="2" IsClosable="False" IsOpen="False" Margin="0,2,0,0" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
            <Button x:Name="RefreshBtn" Click="Refresh_Click"><FontIcon Glyph="&#xE72C;" FontSize="14" /></Button>
            <Button x:Name="CreateBtn" Click="Create_Click" Style="{StaticResource AccentButtonStyle}" />
            <CheckBox x:Name="ColdBootCheck" VerticalAlignment="Center" />
            <ProgressRing x:Name="Busy" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
        </StackPanel>

        <ListView x:Name="AvdList" Grid.Row="4"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="12" Padding="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Target}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
            <Button x:Name="LaunchBtn" Click="Launch_Click" Style="{StaticResource AccentButtonStyle}" />
            <Button x:Name="StopBtn" Click="Stop_Click" />
            <Button x:Name="WipeBtn" Click="Wipe_Click" />
            <Button x:Name="DeleteBtn" Click="Delete_Click" />
        </StackPanel>
    </Grid>
</Page>
