<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinTune.Pages.HotkeyMacroModule"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="980" Spacing="14">

            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon FontSize="22" Glyph="&#xE765;" VerticalAlignment="Center" />
                <TextBlock x:Name="HeaderTitle" Style="{StaticResource TitleTextBlockStyle}" />
            </StackPanel>
            <TextBlock x:Name="HeaderBlurb" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

            <InfoBar x:Name="ResultBar" IsClosable="True" IsOpen="False" />

            <!-- ===================== Global hotkeys ===================== -->
            <TextBlock x:Name="HotkeysHeader" Style="{StaticResource SubtitleTextBlockStyle}" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="12">
                    <!-- chord -->
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <TextBlock x:Name="ChordLabel" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <CheckBox x:Name="CtrlChk" Content="Ctrl" />
                        <CheckBox x:Name="AltChk" Content="Alt" />
                        <CheckBox x:Name="ShiftChk" Content="Shift" />
                        <CheckBox x:Name="WinChk" Content="Win" />
                        <ComboBox x:Name="KeyBox" MinWidth="130" />
                    </StackPanel>

                    <!-- action -->
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <TextBlock x:Name="ActionLabel" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <ComboBox x:Name="ActionBox" MinWidth="220" SelectionChanged="ActionBox_Changed" />
                        <TextBox x:Name="NameBox" MinWidth="180" />
                    </StackPanel>

                    <!-- LaunchApp fields -->
                    <Grid x:Name="LaunchPanel" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TargetBox" Grid.Column="0" />
                        <Button x:Name="BrowseBtn" Grid.Column="1" Click="Browse_Click" />
                        <TextBox x:Name="ArgsBox" Grid.Column="2" />
                    </Grid>

                    <!-- PowerShell field -->
                    <TextBox x:Name="ScriptBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                             FontFamily="Consolas" Visibility="Collapsed" />

                    <!-- SendKeys field -->
                    <TextBox x:Name="KeysBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Visibility="Collapsed" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="AddBindingBtn" Click="AddBinding_Click" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <ListView x:Name="BindingsList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,8,8,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleSwitch Grid.Column="0" IsOn="{Binding Enabled, Mode=TwoWay}" OnContent="" OffContent="" MinWidth="0" Toggled="BindingToggle_Toggled" Tag="{Binding}" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="ChordCell" FontWeight="SemiBold" FontFamily="Consolas" />
                                        <TextBlock x:Name="ActionCell" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="3" Click="RemoveBinding_Click" Tag="{Binding}" Padding="8,4,8,4" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="NoBindings" Margin="16,18,16,18" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- ===================== Text expander ===================== -->
            <TextBlock x:Name="SnippetsHeader" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                        <TextBlock x:Name="ExpanderTitle" FontWeight="SemiBold" FontSize="15" />
                        <TextBlock x:Name="ExpanderStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch x:Name="ExpanderSwitch" Grid.Column="1" Toggled="Expander_Toggled" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Padding="16,14,16,14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TriggerLabel" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <TextBox x:Name="TriggerBox" Grid.Column="1" VerticalAlignment="Center" />
                    <TextBox x:Name="ExpansionBox" Grid.Column="2" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="36" />
                    <Button x:Name="AddSnippetBtn" Grid.Column="3" Click="AddSnippet_Click" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <ListView x:Name="SnippetsList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,8,8,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleSwitch Grid.Column="0" IsOn="{Binding Enabled, Mode=TwoWay}" OnContent="" OffContent="" MinWidth="0" Toggled="SnippetToggle_Toggled" Tag="{Binding}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" FontWeight="SemiBold" FontFamily="Consolas" Text="{Binding Trigger}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding Expansion}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="3" Click="RemoveSnippet_Click" Tag="{Binding}" Padding="8,4,8,4" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="NoSnippets" Margin="16,18,16,18" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Visibility="Collapsed" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
